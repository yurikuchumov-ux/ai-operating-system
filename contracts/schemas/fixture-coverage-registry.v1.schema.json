{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yurikuchumov-ux/ai-operating-system/contracts/schemas/fixture-coverage-registry.v1.schema.json",
  "title": "AI OS Required B0 Fixture Coverage Registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_type", "catalogue_id", "required_fixtures"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "registry_type": {"const": "fixture_coverage"},
    "catalogue_id": {"const": "b0-required-fixtures.v1"},
    "required_fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "failure_mode", "expected"],
        "properties": {
          "id": {"type": "string", "pattern": "^reject-[a-z0-9-]+$"},
          "failure_mode": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": ["valid", "exit_code", "error_codes"],
            "properties": {
              "valid": {"const": false},
              "exit_code": {"const": 1},
              "error_codes": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
                "uniqueItems": true
              }
            }
          }
        }
      }
    }
  }
}
