{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yurikuchumov-ux/ai-operating-system/contracts/schemas/canonical-repositories.v1.schema.json",
  "title": "AI OS Canonical Repository Registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_type", "entries"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "registry_type": {"const": "canonical_repository"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "repository_owner", "repository_name", "repository_sha"],
        "properties": {
          "id": {"$ref": "#/$defs/registry_id"},
          "repository_owner": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+$", "minLength": 1},
          "repository_name": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+$", "minLength": 1},
          "repository_sha": {"$ref": "#/$defs/sha"}
        }
      }
    }
  },
  "$defs": {
    "registry_id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$"},
    "sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
  }
}
