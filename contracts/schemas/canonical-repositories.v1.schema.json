{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yurikuchumov-ux/ai-operating-system/contracts/schemas/canonical-repositories.v1.schema.json",
  "title": "Canonical Repositories Registry",
  "description": "Schema for the canonical repository registry",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "canonical_repositories": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "full_name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "visibility": {
            "type": "string"
          },
          "main_sha": {
            "type": "string"
          },
          "boundary": {
            "type": "string"
          }
        },
        "required": [
          "role",
          "label",
          "owner",
          "name",
          "full_name",
          "url",
          "visibility",
          "main_sha",
          "boundary"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema_version",
    "canonical_repositories"
  ],
  "additionalProperties": false
}
