{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yurikuchumov-ux/ai-operating-system/contracts/schemas/verification.v1.schema.json",
  "title": "AI OS Verification Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "verification_id", "task_id", "execution_id", "subject_sha", "verifier_identity", "passed", "predicate_results", "evidence", "evaluated_at"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "verification_id": {"type": "string", "format": "uuid"},
    "task_id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+#[1-9][0-9]*$"},
    "execution_id": {"type": "string", "format": "uuid"},
    "subject_sha": {"$ref": "#/$defs/sha"},
    "verifier_identity": {"$ref": "#/$defs/identity"},
    "passed": {"type": "boolean"},
    "predicate_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["predicate_id", "passed", "observed", "evidence_artifact_ids", "failure_code"],
        "properties": {
          "predicate_id": {"$ref": "#/$defs/registry_id"},
          "passed": {"type": "boolean"},
          "observed": {},
          "evidence_artifact_ids": {"type": "array", "items": {"$ref": "#/$defs/local_id"}, "uniqueItems": true},
          "failure_code": {"type": ["string", "null"], "pattern": "^[a-z][a-z0-9_]*$"}
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "uri", "sha256"],
        "properties": {
          "id": {"$ref": "#/$defs/local_id"},
          "type": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]*$"},
          "uri": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "evaluated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "local_id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]*$"},
    "registry_id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$"},
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator_principal", "agent_runtime_id", "credential_principal", "delegation_parent", "role"],
      "properties": {
        "operator_principal": {"type": "string", "minLength": 1},
        "agent_runtime_id": {"type": "string", "minLength": 1},
        "credential_principal": {"type": "string", "minLength": 1},
        "delegation_parent": {"type": "string", "minLength": 1},
        "role": {"const": "verifier"}
      }
    }
  }
}
