{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yurikuchumov-ux/ai-operating-system/contracts/schemas/readiness-evidence.v1.schema.json",
  "title": "AI OS Readiness Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "gate_id", "policy_version", "subject_sha", "status", "predicate_results", "evidence", "evaluated_at", "expires_at", "owner"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "gate_id": {"type": "string", "pattern": "^G-[A-Z]+-[0-9]{2}$"},
    "policy_version": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]*$"},
    "subject_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "status": {"enum": ["pass", "fail", "expired"]},
    "predicate_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["predicate_id", "observed", "passed"],
        "properties": {
          "predicate_id": {"$ref": "#/$defs/registry_id"},
          "observed": {},
          "passed": {"type": "boolean"}
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "url", "sha256"],
        "properties": {
          "type": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]*$"},
          "url": {"type": "string", "format": "uri"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "evaluated_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "owner": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "registry_id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$"}
  }
}
