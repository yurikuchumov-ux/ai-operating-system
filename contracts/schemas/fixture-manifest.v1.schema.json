{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yurikuchumov-ux/ai-operating-system/contracts/schemas/fixture-manifest.v1.schema.json",
  "title": "AI OS B0 Fixture Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "fixtures"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "documents", "expected"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "documents": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "path", "sha256"],
              "properties": {
                "type": {"enum": ["task", "result", "verification", "review_attestation", "readiness_evidence"]},
                "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
                "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
              }
            }
          },
          "mutations": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["document_type", "op", "path", "value"],
              "properties": {
                "document_type": {"enum": ["task", "result", "verification", "review_attestation", "readiness_evidence"]},
                "op": {"enum": ["replace", "append"]},
                "path": {"type": "string", "pattern": "^/"},
                "value": {}
              }
            }
          },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": ["valid", "exit_code", "error_codes"],
            "properties": {
              "valid": {"type": "boolean"},
              "exit_code": {"enum": [0, 1]},
              "error_codes": {
                "type": "array",
                "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
                "uniqueItems": true
              }
            }
          }
        }
      }
    }
  }
}
